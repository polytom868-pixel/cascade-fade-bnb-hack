# CoinMarketCap API
CMC_API_KEY=your_cmc_api_key_here

# Trust Wallet Agent Kit
TWAK_WALLET_PASSWORD=your_strong_password_here
TWAK_ACCESS_ID=your_twak_access_id
TWAK_HMAC_SECRET=your_twak_hmac_secret

# BSC RPC (PancakeSwap MEV Guard)
BNB_RPC_URL=https://bscrpc.pancakeswap.finance

# Trading Configuration
TRADE_INTERVAL_MINUTES=30
MAX_POSITIONS=2
MAX_POSITION_PCT=0.10
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_DRAWDOWN_PCT=0.25
HEARTBEAT_SIZE_USD=5
MAX_SLIPPAGE_PCT=0.01
HEARTBEAT_HOUR_UTC=20

# Logging
LOG_LEVEL=INFO

# Mode: paper | live
AGENT_MODE=paper
